<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow layer -->
    <item
        android:left="2dp"
        android:right="2dp"
        android:top="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="@color/cyber_gold_alpha15" />
        </shape>
    </item>
    <!-- Main card body -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="@color/cyber_card" />
            <stroke
                android:width="1dp"
                android:color="@color/cyber_gold_alpha30" />
        </shape>
    </item>
</layer-list>
