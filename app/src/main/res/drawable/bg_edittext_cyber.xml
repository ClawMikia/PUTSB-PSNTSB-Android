<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <solid android:color="@color/cyber_surface_raised" />
            <stroke android:width="2dp" android:color="@color/cyber_gold" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <solid android:color="@color/cyber_surface_raised" />
            <stroke android:width="1.5dp" android:color="@color/cyber_metallic_dark" />
        </shape>
    </item>
</selector>
