<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base Cyberpunk Theme -->
    <style name="Theme.DebtTracker" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Colors -->
        <item name="colorPrimary">@color/cyber_gold</item>
        <item name="colorPrimaryDark">@color/cyber_gold_dark</item>
        <item name="colorPrimaryVariant">@color/cyber_gold_dark</item>
        <item name="colorOnPrimary">@color/text_on_gold</item>
        <item name="colorSecondary">@color/neon_amber</item>
        <item name="colorSecondaryVariant">@color/cyber_gold_dark</item>
        <item name="colorOnSecondary">@color/text_on_gold</item>

        <!-- Surface & Background -->
        <item name="android:colorBackground">@color/cyber_black</item>
        <item name="colorSurface">@color/cyber_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorError">@color/neon_red_alert</item>
        <item name="colorOnError">@color/text_primary</item>

        <!-- Status Bar & Navigation Bar -->
        <item name="android:statusBarColor">@color/status_bar_color</item>
        <item name="android:navigationBarColor">@color/nav_bar_color</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Window -->
        <item name="android:windowBackground">@color/cyber_black</item>
        <item name="android:windowAnimationStyle">@style/WindowAnimation.Cyber</item>

        <!-- Explicit Text Colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorTertiary">@color/text_tertiary</item>
        <item name="android:editTextColor">@color/text_primary</item>

        <!-- Shapes -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.DebtTracker.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.DebtTracker.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.DebtTracker.Large</item>

        <!-- Text Appearance -->
        <item name="textAppearanceHeadline1">@style/TextAppearance.DebtTracker.Hero</item>
        <item name="textAppearanceHeadline2">@style/TextAppearance.DebtTracker.Title</item>
        <item name="textAppearanceHeadline3">@style/TextAppearance.DebtTracker.Subtitle</item>
        <item name="textAppearanceBody1">@style/TextAppearance.DebtTracker.Body</item>
        <item name="textAppearanceBody2">@style/TextAppearance.DebtTracker.Caption</item>

        <!-- Components -->
        <item name="materialCardViewStyle">@style/Widget.DebtTracker.CardView</item>
        <item name="extendedFloatingActionButtonStyle">@style/Widget.DebtTracker.FAB</item>
        <item name="bottomNavigationStyle">@style/Widget.DebtTracker.BottomNavigation</item>
        <item name="toolbarStyle">@style/Widget.DebtTracker.Toolbar</item>
        <item name="textInputStyle">@style/Widget.DebtTracker.TextInputLayout</item>
        <item name="materialButtonStyle">@style/Widget.DebtTracker.Button</item>
        <item name="appBarLayoutStyle">@style/Widget.DebtTracker.AppBarLayout</item>
        <item name="popupMenuStyle">@style/Widget.DebtTracker.PopupMenu</item>
        <item name="android:popupMenuStyle">@style/Widget.DebtTracker.PopupMenu</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.DebtTracker.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/cyber_black_deep</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_animated_icon</item>
        <item name="windowSplashScreenAnimationDuration">1200</item>
        <item name="postSplashScreenTheme">@style/Theme.DebtTracker</item>
        <item name="android:statusBarColor">@color/cyber_black_deep</item>
        <item name="android:navigationBarColor">@color/cyber_black_deep</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Shape Appearances -->
    <style name="ShapeAppearance.DebtTracker.Small" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearance.DebtTracker.Medium" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.DebtTracker.Large" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <!-- Window Animations -->
    <style name="WindowAnimation.Cyber" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>

    <!-- Text Appearances -->
    <style name="TextAppearance.DebtTracker.Hero" parent="TextAppearance.MaterialComponents.Headline1">
        <item name="android:textColor">@color/cyber_gold</item>
        <item name="android:textSize">@dimen/text_hero</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <style name="TextAppearance.DebtTracker.Title" parent="TextAppearance.MaterialComponents.Headline2">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="TextAppearance.DebtTracker.Subtitle" parent="TextAppearance.MaterialComponents.Headline3">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_xl</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <style name="TextAppearance.DebtTracker.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.DebtTracker.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <style name="TextAppearance.DebtTracker.Label" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/cyber_gold</item>
        <item name="android:textSize">@dimen/text_xs</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="TextAppearance.DebtTracker.Amount" parent="TextAppearance.MaterialComponents.Headline2">
        <item name="android:textColor">@color/cyber_gold</item>
        <item name="android:textSize">@dimen/text_xxl</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <!-- CardView -->
    <style name="Widget.DebtTracker.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/cyber_card</item>
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="strokeColor">@color/cyber_card_border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.DebtTracker.CardView.Gold" parent="Widget.DebtTracker.CardView">
        <item name="strokeColor">@color/cyber_gold_alpha30</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.DebtTracker.CardView.Debt" parent="Widget.DebtTracker.CardView">
        <item name="strokeColor">@color/debt_owed_dim</item>
    </style>

    <style name="Widget.DebtTracker.CardView.Lent" parent="Widget.DebtTracker.CardView">
        <item name="strokeColor">@color/debt_lent_dim</item>
    </style>

    <!-- FAB -->
    <style name="Widget.DebtTracker.FAB" parent="Widget.MaterialComponents.ExtendedFloatingActionButton">
        <item name="backgroundTint">@color/cyber_gold</item>
        <item name="tint">@color/text_on_gold</item>
        <item name="android:textColor">@color/text_on_gold</item>
        <item name="cornerRadius">28dp</item>
        <item name="elevation">8dp</item>
    </style>

    <!-- Bottom Navigation -->
    <style name="Widget.DebtTracker.BottomNavigation" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/cyber_surface</item>
        <item name="itemIconTint">@color/bottom_nav_item_color</item>
        <item name="itemTextColor">@color/bottom_nav_item_color</item>
        <item name="itemRippleColor">@color/cyber_gold_alpha15</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- Toolbar -->
    <style name="Widget.DebtTracker.Toolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/cyber_black</item>
        <item name="titleTextColor">@color/cyber_gold</item>
        <item name="subtitleTextColor">@color/text_secondary</item>
        <item name="navigationIconTint">@color/cyber_gold</item>
    </style>

    <!-- AppBarLayout -->
    <style name="Widget.DebtTracker.AppBarLayout" parent="Widget.Design.AppBarLayout">
        <item name="android:background">@color/cyber_black</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- TextInputLayout -->
    <style name="Widget.DebtTracker.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/cyber_surface_raised</item>
        <item name="boxStrokeColor">@color/edittext_stroke_color</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/edittext_hint_color</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
        <item name="counterTextColor">@color/text_tertiary</item>
        <item name="errorTextColor">@color/neon_red_alert</item>
        <item name="errorIconTint">@color/neon_red_alert</item>
        <item name="startIconTint">@color/cyber_gold</item>
        <item name="endIconTint">@color/cyber_gold</item>
        <item name="prefixTextColor">@color/text_primary</item>
        <item name="suffixTextColor">@color/text_primary</item>
    </style>

    <!-- Button Styles -->
    <style name="Widget.DebtTracker.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/cyber_gold</item>
        <item name="android:textColor">@color/text_on_gold</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="elevation">0dp</item>
        <item name="android:minHeight">52dp</item>
    </style>

    <style name="Widget.DebtTracker.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/cyber_gold</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textColor">@color/cyber_gold</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="android:minHeight">52dp</item>
        <item name="rippleColor">@color/cyber_gold_alpha15</item>
    </style>

    <style name="Widget.DebtTracker.Button.Danger" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/neon_red_alert</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textColor">@color/neon_red_alert</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="android:minHeight">52dp</item>
        <item name="rippleColor">@color/glow_red</item>
    </style>

    <style name="Widget.DebtTracker.Button.Ghost" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">@dimen/text_md</item>
        <item name="rippleColor">@color/cyber_gold_alpha15</item>
    </style>

    <!-- Dialog Theme -->
    <style name="Theme.DebtTracker.Dialog" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="android:background">@color/cyber_surface</item>
        <item name="colorPrimary">@color/cyber_gold</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorAlertDialogListItem">@color/text_primary</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.DebtTracker.Button</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.DebtTracker.Button.Ghost</item>
        <item name="android:colorBackground">@color/cyber_surface</item>
    </style>

    <!-- Chip Style -->
    <style name="Widget.DebtTracker.Chip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="android:textColor">@color/chip_text_color</item>
        <item name="chipBackgroundColor">@color/chip_bg_color</item>
        <item name="chipStrokeColor">@color/cyber_gold_alpha30</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="checkedIconTint">@color/text_on_gold</item>
        <item name="chipCornerRadius">8dp</item>
    </style>

    <!-- Sort Menu Popup -->
    <style name="Widget.DebtTracker.PopupMenu" parent="Widget.MaterialComponents.PopupMenu">
        <item name="android:popupBackground">@drawable/popup_menu_bg</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Switch Style -->
    <style name="Widget.DebtTracker.Switch" parent="Widget.MaterialComponents.CompoundButton.Switch">
        <item name="thumbTint">@color/switch_thumb_color</item>
        <item name="trackTint">@color/switch_track_color</item>
    </style>

    <!-- Progress Bar -->
    <style name="Widget.DebtTracker.ProgressBar" parent="Widget.AppCompat.ProgressBar.Horizontal">
        <item name="android:progressDrawable">@drawable/progress_horizontal_cyber</item>
        <item name="android:minHeight">6dp</item>
        <item name="android:maxHeight">6dp</item>
    </style>

</resources>
