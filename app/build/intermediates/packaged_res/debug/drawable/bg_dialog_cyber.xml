<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <solid android:color="@color/cyber_surface" />
            <stroke android:width="1dp" android:color="@color/cyber_gold_alpha30" />
        </shape>
    </item>
    <!-- Top accent line -->
    <item android:gravity="top" android:height="3dp" android:left="32dp" android:right="32dp">
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="16dp" android:topRightRadius="16dp" />
            <solid android:color="@color/cyber_gold" />
        </shape>
    </item>
</layer-list>
