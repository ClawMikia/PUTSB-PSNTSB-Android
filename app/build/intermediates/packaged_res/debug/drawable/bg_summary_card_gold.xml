<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow backing -->
    <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@color/cyber_gold_alpha15" />
        </shape>
    </item>
    <!-- Card body -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#1AFFD700"
                android:centerColor="@color/cyber_surface"
                android:endColor="@color/cyber_card" />
            <stroke android:width="1dp" android:color="@color/cyber_gold_alpha60" />
        </shape>
    </item>
</layer-list>
